/* ==================== 页面容器 ==================== */
.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* ==================== 筛选标签 ==================== */
.filter-tabs {
  display: flex;
  padding: 12px 16px 0px 16px;
  gap: 24px;
  border-bottom: 1px solid #f0f0f0;
}

.filter-tab {
  font-size: 13px;
  color: #969799;
  padding-bottom: 8px;
  position: relative;
}

.filter-tab.active {
  color: #323233;
  font-weight: 500;
}

.filter-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2px;
  background-color: #07c160;
}

/* ==================== 列表容器 ==================== */
.list-container {
  flex: 1;
}

/* ==================== 空状态 ==================== */
.empty-tip {
  text-align: center;
  color: #969799;
  padding: 60px 0;
  font-size: 14px;
}

/* ==================== 优先级分组 ==================== */
.priority-section {
  padding: 10px;
}

.priority-label {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  color: #646566;
  margin-bottom: 12px;
}

.priority-indicator {
  width: 3px;
  height: 14px;
  border-radius: 2px;
}

.priority-indicator.priority-high {
  background-color: #ff4d4f;
}

.priority-indicator.priority-normal {
  background-color: #13EC5B;
}

/* ==================== 待办卡片列表 ==================== */
.todo-cards {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.todo-card {
  display: flex;
  align-items: flex-start;
  background-color: #ffffff;
  border-radius: 8px;
  padding: 16px;
  gap: 12px;
}

.todo-card-completed {
  opacity: 0.7;
}

/* ==================== 复选框 ==================== */
.todo-checkbox {
  width: 20px;
  height: 20px;
  border: 2px solid #c8c9cc;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2px;
}

.todo-checkbox.checked {
  background-color: #07c160;
  border-color: #07c160;
}

.check-icon {
  color: #ffffff;
  font-size: 12px;
  font-weight: bold;
}

/* ==================== 待办内容 ==================== */
.todo-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.todo-title {
  font-size: 16px;
  font-weight: 500;
  color: #323233;
  line-height: 1.4;
}

.todo-title-completed {
  color: #969799;
  text-decoration: line-through;
}

.todo-desc {
  font-size: 13px;
  color: #969799;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 200px;
}

.todo-meta {
  display: flex;
  gap: 8px;
  margin-top: 4px;
}

.todo-time {
  font-size: 12px;
  color: #ff4d4f;
  background-color: #fff1f0;
  padding: 2px 8px;
  border-radius: 4px;
}

/* ==================== 滑动操作按钮 ==================== */
.swipe-right-actions {
  display: flex;
  align-items: center;
  height: 100%;
}

.action-btn {
  width: 60px;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 14px;
}

.action-btn-abandon {
  background-color: #969799;
  border-radius: 0 6px 6px 0;
}

/* ==================== 优先级空状态 ==================== */
.priority-empty {
  text-align: center;
  padding: 20px;
  font-size: 14px;
  color: #969799;
}

/* ==================== 编辑对话框 ==================== */
.edit-dialog {
  padding: 16px;
}

.dialog-field {
  margin-bottom: 8px;
}

.dialog-field-row {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  gap: 10px;
}

.dialog-label {
  font-size: 14px;
  color: #323233;
}

.dialog-input {
  width: 100%;
  height: 40px;
  padding: 0 12px;
  border: 1px solid #ebedf0;
  border-radius: 4px;
  font-size: 14px;
  box-sizing: border-box;
}

.dialog-textarea {
  width: 100%;
  height: 80px;
  padding: 8px 12px;
  border: 1px solid #ebedf0;
  border-radius: 4px;
  font-size: 14px;
}

.dialog-text {
  font-size: 14px;
  color: #323233;
  padding: 8px 0;
  line-height: 1.5;
  flex: 1;
}

/* ==================== 优先级选项 ==================== */
.priority-options {
  display: flex;
  gap: 12px;
  align-items: center;
}

.priority-option {
  padding: 8px 20px;
  border-radius: 4px;
  font-size: 14px;
  color: #646566;
  background-color: #f5f5f5;
  border: none;
  transition: all 0.3s ease;
}

.priority-option.active {
  color: #ffffff;
}

.priority-option.active.high {
  background-color: #ff4d4f;
}

.priority-option.active.normal {
  background-color: #13EC5B;
}
