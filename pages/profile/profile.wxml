<view class="container">
  <!-- 未登录状态 -->
  <view class="unlogin-section" wx:if="{{!isLoggedIn}}">
    <view class="avatar-box">
      <view class="avatar-bg">
        <image class="avatar-icon" src="/assets/icon/default-avatar.png" mode="aspectFill"></image>
      </view>
    </view>
    <view class="unlogin-title">{{text.notLoggedIn}}</view>
    <view class="login-btn" bindtap="onShowLoginPopup">
      <text class="login-btn-icon">☰</text>
      <text class="login-btn-text">{{text.loginBtnText}}</text>
    </view>
  </view>

  <!-- 已登录状态 -->
  <view class="logged-in-section" wx:if="{{isLoggedIn}}">
    <view class="avatar-box">
      <view class="avatar-bg">
        <image class="avatar-icon logged-avatar" src="{{userInfo.avatarUrl || '/assets/icon/default-avatar.png'}}" mode="aspectFill"></image>
      </view>
    </view>
    <view class="user-name">{{userInfo.nickName || text.defaultNickname}}</view>
    <view class="join-date">{{joinDateText}}</view>
    
    <!-- 统计卡片 -->
    <view class="stats-row">
      <view class="stat-card">
        <text class="stat-num">{{stats.total || 0}}</text>
        <text class="stat-label">任务总数</text>
      </view>
      <view class="stat-card highlight">
        <text class="stat-num">{{stats.completed || 0}}</text>
        <text class="stat-label">已完成</text>
      </view>
      <view class="stat-card">
        <text class="stat-num">{{stats.pending || 0}}</text>
        <text class="stat-label">进行中</text>
      </view>
    </view>
  </view>

  <!-- 账户管理 -->
  <view class="section-title" wx:if="{{isLoggedIn}}">账户管理</view>
  
  <!-- 功能菜单 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="onDataManage" wx:if="{{isLoggedIn}}">
      <view class="menu-icon-wrapper green">
        <text class="menu-icon-text">💾</text>
      </view>
      <text class="menu-text">数据管理</text>
      <view class="menu-arrow">›</view>
    </view>
    
    <view class="menu-item" bindtap="onAbout">
      <view class="menu-icon-wrapper green">
        <text class="menu-icon-text">i</text>
      </view>
      <text class="menu-text">关于应用</text>
      <view class="menu-arrow">›</view>
    </view>
    
    <view class="menu-item" bindtap="onLogout" wx:if="{{isLoggedIn}}">
      <view class="menu-icon-wrapper green">
        <text class="menu-icon-text">🚪</text>
      </view>
      <text class="menu-text">退出登录</text>
      <view class="menu-arrow">›</view>
    </view>
  </view>
</view>

<!-- 登录确认弹窗 -->
<view class="login-popup {{showLoginPopup ? 'show' : ''}}" bindtap="onCloseLoginPopup">
  <view class="login-popup-content" catchtap="stopPropagation">
    <view class="login-popup-header">
      <image class="login-popup-app-icon" src="/assets/icon/xucheng.png" mode="aspectFill"></image>
      <text class="login-popup-app-name">{{loginText.appName}}</text>
    </view>
    <view class="login-popup-title">{{loginText.title}}</view>
    
    <view class="login-popup-form">
      <button class="login-popup-avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
        <image class="login-popup-avatar" src="{{(tempUserInfo && tempUserInfo.avatarUrl) || '/assets/icon/default-avatar.png'}}" mode="aspectFill"></image>
        <text class="login-popup-avatar-tip">{{loginText.avatarTip}}</text>
      </button>
      <input type="nickname" class="login-popup-input" placeholder="{{loginText.nicknamePlaceholder}}" value="{{tempUserInfo ? tempUserInfo.nickName : ''}}" bindinput="onNickNameInput"/>
    </view>
    
    <view class="login-popup-btns">
      <view class="login-popup-btn cancel" bindtap="onCloseLoginPopup">{{loginText.cancelBtn}}</view>
      <view class="login-popup-btn confirm" bindtap="onConfirmLogin">{{loginText.confirmBtn}}</view>
    </view>
  </view>
</view>
